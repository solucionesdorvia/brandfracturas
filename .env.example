# Copiá este archivo a .env y completá los valores.

# Postgres
DATABASE_URL="postgresql://branded:branded@localhost:54337/branded_docs?schema=public"

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambiame-en-produccion"

# Id del BrandProfile activo (lo imprime `npm run db:seed`). Opcional:
# si queda vacío, se usa el primer BrandProfile de la base.
DEFAULT_TENANT_ID=""

# Base URL que usa Puppeteer para las rutas de render (la URL pública en prod).
RENDER_BASE_URL="http://localhost:3000"

# Directorio del Storage local (en prod, montar un volumen o usar S3).
STORAGE_DIR="./storage"

# Usuario inicial que crea el seed.
SEED_USER_EMAIL="prueba@ger.com"
SEED_USER_PASSWORD="prueba123"

# Railway/serverless: 1 para usar @sparticuz/chromium (requiere instalarlo).
# PUPPETEER_USE_SPARTICUZ="0"
